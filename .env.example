SDQP_ENVIRONMENT=dev
SDQP_CONFIG_ROOT=configs
SDQP_SECRETS_FILE=configs/secrets.local.toml
SDQP_API_HOST=127.0.0.1
SDQP_API_PORT=8080
SDQP_WORKER_HOST=127.0.0.1
SDQP_WORKER_PORT=8081
SDQP_FRONTEND_PORT=4173
SDQP_FRONTEND_API_BASE_URL=http://127.0.0.1:8080
SDQP_POSTGRES_DSN=postgres://sdqp:sdqp@127.0.0.1:5432/sdqp
SDQP_CLICKHOUSE_HTTP_URL=http://127.0.0.1:8123
SDQP_S3_ENDPOINT=http://127.0.0.1:9002
SDQP_KAFKA_BROKERS=127.0.0.1:9092
SDQP_OIDC_CLIENT_SECRET=replace-me
SDQP_HR_TOKEN=replace-me
SDQP_TSA_API_KEY=replace-me
SDQP_LOG_FILTER=info,sdqp_api=info,sdqp_worker=info
